<UserControl x:Class="StickyDo.Widget.Controls.NotesListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:StickyDo.Widget.Controls"
             mc:Ignorable="d"
             Background="#F5F5F5">
    <Grid x:Name="ContentGrid">
        <!-- Notes List -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#F5F5F5"
                      x:Name="NotesScrollViewer">
            <ItemsControl x:Name="NotesItemsControl"
                          ItemsSource="{Binding FilteredNotes, Mode=OneWay}"
                          Padding="24,16,24,16">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <local:StickyNoteListItem
                            Title="{Binding Title, Mode=OneWay}"
                            NoteContent="{Binding Content, Mode=OneWay}"
                            Status="{Binding Status, Mode=OneWay}"
                            LastModified="{Binding LastModified, Mode=OneWay}"
                            ColorBrush="{Binding ColorArgb, Mode=OneWay, Converter={StaticResource ColorArgbToBrushConverter}}"
                            Margin="0,0,0,12"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty State -->
        <StackPanel x:Name="EmptyStatePanel" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="Collapsed" Background="#F5F5F5">
            <TextBlock Text="📋" FontSize="64" Foreground="#D0D0D0"
                       HorizontalAlignment="Center" Margin="0,0,0,16"/>
            <TextBlock Text="No notes yet" FontSize="18" FontWeight="500" Foreground="#666666"
                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock Text="Start by creating your first sticky note to stay organized."
                       FontSize="13" Foreground="#999999" HorizontalAlignment="Center"
                       Margin="0,0,0,24" MaxWidth="300" TextAlignment="Center"/>
            <Button Content="+ Create New Note" Padding="24,12,24,12"
                    FontSize="13" FontWeight="500"
                    Background="#0066CC" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Command="{Binding CreateNoteCommand}" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
