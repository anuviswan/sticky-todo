<UserControl x:Class="StickyDo.Widget.StickyNoteTaskItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Height="32">

    <Border Background="Transparent" Padding="0,0,0,0">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Checkbox -->
            <CheckBox Grid.Column="0"
                      IsChecked="{Binding IsCompleted, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      VerticalAlignment="Center"
                      Margin="0,0,8,0"
                      Command="{Binding ToggleCompletionCommand}"/>

            <!-- Task Title -->
            <TextBlock Grid.Column="1"
                       Text="{Binding Title}"
                       FontSize="12"
                       Foreground="#1F1F1F"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                <Setter Property="Foreground" Value="#999999"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Delete Button -->
            <Button Grid.Column="2"
                    Width="20"
                    Height="20"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    Padding="0"
                    VerticalAlignment="Center"
                    Margin="8,0,0,0"
                    Command="{Binding DeleteCommand}"
                    ToolTip="Delete task">
                <TextBlock Text="✕" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#CCCCCC"/>
            </Button>
        </Grid>
    </Border>
</UserControl>
