<UserControl x:Class="StickyDo.Widget.Controls.StickyNoteEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:StickyDo.Widget.Controls"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="500"
             Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header/Title -->
        <TextBlock Grid.Row="0" Text="{Binding Title, Mode=OneWay, StringFormat='Edit Note: {0}'}"
                   FontSize="16" FontWeight="500" Foreground="#1F1F1F"
                   Padding="16,12,16,8"/>

        <!-- Title input -->
        <Border Grid.Row="1" Padding="16,0,16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Title:" VerticalAlignment="Center"
                           FontSize="13" Foreground="#666666" Margin="0,0,12,0"/>
                <TextBox Grid.Column="1" x:Name="TitleTextBox"
                         Text="{Binding Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="13" Padding="8,6,8,6" BorderThickness="0.5"
                         BorderBrush="#D0D0D0" Background="White"/>
            </Grid>
        </Border>

        <!-- Content editor -->
        <Border Grid.Row="2" Padding="16,0,16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Content:" VerticalAlignment="Top"
                           FontSize="13" Foreground="#666666" Margin="0,6,12,0"/>
                <TextBox Grid.Column="1" x:Name="ContentTextBox"
                         Text="{Binding NoteContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="12" Padding="8,6,8,6" BorderThickness="0.5"
                         BorderBrush="#D0D0D0" Background="White"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"/>
            </Grid>
        </Border>

        <!-- Status and color row -->
        <Border Grid.Row="3" Padding="16,0,16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Status:" VerticalAlignment="Center"
                           FontSize="13" Foreground="#666666" Margin="0,0,12,0"/>
                <ComboBox Grid.Column="1" x:Name="StatusComboBox"
                          SelectedItem="{Binding Status, Mode=TwoWay}"
                          FontSize="12" Padding="6,4,6,4" Height="30"
                          Background="White" BorderBrush="#D0D0D0" BorderThickness="0.5">
                    <ComboBoxItem Content="Active"/>
                    <ComboBoxItem Content="Completed"/>
                    <ComboBoxItem Content="Archived"/>
                    <ComboBoxItem Content="Urgent"/>
                </ComboBox>

                <TextBlock Grid.Column="2" Text="Color:" VerticalAlignment="Center"
                           FontSize="13" Foreground="#666666" Margin="12,0,12,0"/>
                <Border Grid.Column="3" Background="{Binding ColorBrush, Mode=OneWay}"
                        BorderBrush="#D0D0D0" BorderThickness="0.5" Height="30"
                        CornerRadius="2">
                    <TextBlock Text="Color Picker" VerticalAlignment="Center"
                               HorizontalAlignment="Center" FontSize="11"
                               Foreground="White"/>
                </Border>
            </Grid>
        </Border>

        <!-- Action buttons -->
        <Border Grid.Row="4" Background="#F5F5F5" Padding="16,12,16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding CharacterCount, Mode=OneWay, StringFormat='Characters: {0}'}"
                           VerticalAlignment="Center" FontSize="11" Foreground="#999999"/>

                <Button Grid.Column="1" x:Name="SaveButton"
                        Content="Save" Padding="16,6,16,6" FontSize="12"
                        Background="#0066CC" Foreground="White"
                        BorderThickness="0"
                        Click="OnSaveClick"/>

                <Button Grid.Column="3" x:Name="CancelButton"
                        Content="Cancel" Padding="16,6,16,6" FontSize="12"
                        Background="Transparent" Foreground="#0066CC"
                        BorderBrush="#0066CC" BorderThickness="0.5"
                        Click="OnCancelClick"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
