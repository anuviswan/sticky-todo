<Application x:Class="StickyDo.Widget.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:StickyDo.Widget"
             xmlns:converters="clr-namespace:StickyDo.Widget.Converters"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:ColorArgbToBrushConverter x:Key="ColorArgbToBrushConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
