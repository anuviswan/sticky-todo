<Application x:Class="StickyDo.Widget.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:StickyDo.Widget"
             xmlns:converters="clr-namespace:StickyDo.Widget.Converters"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:ColorArgbToBrushConverter x:Key="ColorArgbToBrushConverter"/>
            <converters:CompareColorConverter x:Key="CompareColorConverter"/>
            <converters:ColorNameConverter x:Key="ColorNameConverter"/>
            <DropShadowEffect x:Key="CheckmarkShadow" BlurRadius="2" ShadowDepth="1" Opacity="0.6"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
