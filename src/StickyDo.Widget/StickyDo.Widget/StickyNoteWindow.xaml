<Window x:Class="StickyDo.Widget.StickyNoteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StickyDo.Widget"
        xmlns:controls="clr-namespace:StickyDo.Widget;assembly=StickyDo.Widget.Controls"
        mc:Ignorable="d"
        Title="Sticky Note" Height="400" Width="300"
        Background="White"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Topmost="False">

    <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="White" BorderBrush="#E8E8E8" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
                <Grid Margin="12,0,12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Note Title -->
                    <TextBlock Grid.Column="0"
                               Text="{Binding Title, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                               FontSize="13"
                               FontWeight="500"
                               Foreground="#1F1F1F"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>

                    <!-- Menu Button (Placeholder) -->
                    <Button Grid.Column="1"
                            Width="28"
                            Height="28"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center">
                        <TextBlock Text="..." FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#999999"/>
                    </Button>

                    <!-- Close Button -->
                    <Button Grid.Column="2"
                            Width="28"
                            Height="28"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="OnCloseButtonClick"
                            VerticalAlignment="Center">
                        <TextBlock Text="✕" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#999999"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Task List -->
            <Border Grid.Row="1" Background="White" Padding="12,12,12,12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Tasks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:StickyNoteTaskItem Margin="0,0,0,6"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- Add Task Bar -->
            <Border Grid.Row="2" Background="#F9F9F9" BorderBrush="#E8E8E8" BorderThickness="0,1,0,0" Padding="12,8,12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Add Task Input -->
                    <Border Grid.Column="0" BorderBrush="#D8D8D8" BorderThickness="1">
                        <Grid>
                            <TextBox Text="{Binding NewTaskTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="12"
                                     Padding="8,4,8,4"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Height="28"
                                     VerticalAlignment="Center"/>
                            <TextBlock Text="Add a task..."
                                       FontSize="12"
                                       Foreground="#CCCCCC"
                                       Padding="8,4,8,4"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding NewTaskTitle, Mode=OneWay}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding NewTaskTitle, Mode=OneWay}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                        <Setter Property="Visibility" Value="Hidden"/>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Add Button -->
                    <Button Grid.Column="1"
                            Content="+ Add"
                            Padding="8,4,8,4"
                            FontSize="11"
                            FontWeight="500"
                            Background="#0066CC"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="8,0,0,0"
                            Command="{Binding AddTaskCommand}"
                            Height="28"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
