<Window x:Class="StickyDo.Widget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StickyDo.Widget"
        xmlns:controls="clr-namespace:StickyDo.Widget.Controls;assembly=StickyDo.Widget.Controls"
        xmlns:converters="clr-namespace:StickyDo.Widget.Converters"
        mc:Ignorable="d"
        Title="StickyDo" Height="700" Width="1000"
        Background="White" ResizeMode="CanResizeWithGrip"
        WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="True">

    <Border Background="White" BorderBrush="#D0D0D0" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Unified Header spanning entire width -->
            <Border Grid.Row="0" Background="#F8F8F8" BorderBrush="#E8E8E8" BorderThickness="0,0,0,1" MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
                <Grid Margin="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- App Name -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,32,0">
                        <TextBlock Text="Sticky TODO" FontSize="14" FontWeight="600" Foreground="#1F1F1F"/>
                    </StackPanel>

                    <!-- Search Bar -->
                    <Border Grid.Column="1" Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                            Padding="12,8,12,8" VerticalAlignment="Center" Margin="0,0,16,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Search Icon -->
                            <TextBlock Grid.Column="0" Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>

                            <!-- Search TextBox -->
                            <TextBox Grid.Column="1" x:Name="SearchTextBox"
                                     FontSize="13"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#666666"
                                     Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Background" Value="Transparent"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Grid>
                    </Border>

                    <!-- Settings Button -->
                    <Button Grid.Column="2" Width="36" Height="36" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" ToolTip="Settings" Margin="0,0,8,0">
                        <TextBlock Text="⚙️" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>

                    <!-- New Note Button -->
                    <Button Grid.Column="3" Content="+ New Note" Padding="12,6,12,6"
                            FontSize="12" FontWeight="500"
                            Background="#0066CC" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            Command="{Binding CreateNoteCommand}" Margin="0,0,16,0"/>

                    <!-- Minimize Button -->
                    <Button Grid.Column="4" Width="40" Height="40" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" ToolTip="Minimize"
                            Command="{Binding MinimizeWindowCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                        <TextBlock Text="−" FontSize="18" FontWeight="300" Foreground="#666666"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>

                    <!-- Close Button -->
                    <Button Grid.Column="5" Width="40" Height="40" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" ToolTip="Close"
                            Command="{Binding CloseWindowCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                        <TextBlock Text="✕" FontSize="16" FontWeight="400" Foreground="#666666"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Main Content Area -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Sidebar Navigation -->
                <controls:SidebarNavigation Grid.Column="0"/>

                <!-- Notes List View -->
                <Border Grid.Column="1" Background="White">
                    <controls:NotesListView/>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
