<Window x:Class="StickyDo.Widget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StickyDo.Widget"
        xmlns:controls="clr-namespace:StickyDo.Widget.Controls;assembly=StickyDo.Widget.Controls"
        mc:Ignorable="d"
        Title="Sticky TODO" Height="700" Width="1000"
        Background="White" ResizeMode="CanResizeWithGrip"
        WindowStyle="SingleBorderWindow" ShowInTaskbar="True">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Sidebar Navigation -->
        <Border Grid.Column="0" Background="#FFFBF0" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0" Padding="16,16,16,16">
            <StackPanel Orientation="Vertical">
                <!-- App Header -->
                <TextBlock Text="Sticky TODO" FontSize="18" FontWeight="600" Foreground="#1F1F1F" Margin="0,0,0,8"/>
                <TextBlock Text="Productive Session" FontSize="11" Foreground="#999999" Margin="0,0,0,24"/>

                <!-- Navigation Items -->
                <Button x:Name="AllNotesNavButton" Style="{StaticResource NavButtonStyle}"
                        Click="OnAllNotesNavClick" Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="📋" FontSize="16" Margin="0,0,12,0"/>
                        <TextBlock Text="All Notes" FontSize="13" Foreground="#1F1F1F" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="FavoritesNavButton" Style="{StaticResource NavButtonStyle}"
                        Click="OnFavoritesNavClick" Margin="0,0,0,24">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⭐" FontSize="16" Margin="0,0,12,0"/>
                        <TextBlock Text="Favorites" FontSize="13" Foreground="#999999" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Trash -->
                <Button x:Name="TrashNavButton" Style="{StaticResource NavButtonStyle}"
                        Click="OnTrashNavClick" Margin="0,0,0,0" VerticalAlignment="Bottom">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🗑" FontSize="16" Margin="0,0,12,0"/>
                        <TextBlock Text="Trash" FontSize="13" Foreground="#999999" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header with Search and New Note Button -->
            <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1"
                    Padding="24,16,24,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search Bar -->
                    <Border Grid.Column="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                            Padding="12,8,12,8" VerticalAlignment="Center">
                        <TextBox x:Name="SearchTextBox"
                                 FontSize="13"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="#666666"
                                 TextChanged="OnSearchTextChanged"/>
                    </Border>

                    <!-- New Note Button -->
                    <Button Grid.Column="1" Content="+ New Note" Padding="16,8,16,8"
                            FontSize="13" FontWeight="500"
                            Background="#0066CC" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            Click="OnCreateNoteClick" Margin="16,0,0,0"/>
                </Grid>
            </Border>

            <!-- Notes Content Area -->
            <Border Grid.Row="1" Background="White">
                <Grid x:Name="ContentGrid">
                    <!-- Notes List -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="White"
                                  x:Name="NotesScrollViewer">
                        <ItemsControl x:Name="NotesItemsControl"
                                      ItemsSource="{Binding FilteredNotes, Mode=OneWay}"
                                      Padding="24,16,24,16">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <controls:StickyNoteListItem
                                        Title="{Binding Title, Mode=OneWay}"
                                        NoteContent="{Binding Content, Mode=OneWay}"
                                        Status="{Binding Status, Mode=OneWay}"
                                        LastModified="{Binding LastModified, Mode=OneWay}"
                                        ColorBrush="{Binding ColorBrush, Mode=OneWay}"
                                        Margin="0,0,0,12"
                                        MouseLeftButtonUp="OnNoteItemClick"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Empty State -->
                    <StackPanel x:Name="EmptyStatePanel" VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="Collapsed">
                        <TextBlock Text="📋" FontSize="64" Foreground="#D0D0D0"
                                   HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <TextBlock Text="No notes yet" FontSize="18" FontWeight="500" Foreground="#666666"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="Start by creating your first sticky note to stay organized."
                                   FontSize="13" Foreground="#999999" HorizontalAlignment="Center"
                                   Margin="0,0,0,24" MaxWidth="300" TextAlignment="Center"/>
                        <Button Content="+ Create New Note" Padding="24,12,24,12"
                                FontSize="13" FontWeight="500"
                                Background="#0066CC" Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                Click="OnCreateNoteClick" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>

    <Window.Resources>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#1F1F1F"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8,12,8"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderThickness="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFF4E6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FFE8CC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
</Window>
